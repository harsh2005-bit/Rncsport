generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum GameType {
  CRASH
  DICE
  MINES
  PLINKO
  SLOTS
}

enum BetStatus {
  PENDING
  WON
  LOST
  CANCELLED
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  username      String    @unique
  email         String    @unique
  passwordHash  String
  role          Role      @default(USER)
  balance       Float     @default(1000.0) // Demo balance
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bets          Bet[]
  sessions      Session[]

  @@map("users")
}

model Bet {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id])
  gameType    GameType
  amount      Float
  multiplier  Float?
  payout      Float?
  status      BetStatus @default(PENDING)
  metadata    Json?     // Specific game data (e.g., mine positions)
  createdAt   DateTime  @default(now())

  @@map("bets")
}

model Game {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  type        GameType
  isActive    Boolean  @default(true)
  minBet      Float    @default(1.0)
  maxBet      Float    @default(10000.0)
  houseEdge   Float    @default(0.01) // 1% edge

  @@map("games")
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

model Lead {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  mobileNumber String   @map("mobile_number")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("leads")
}
